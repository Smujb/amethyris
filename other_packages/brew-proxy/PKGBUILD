# PKGBUILD for brew-proxy maintained by SmuJayB

pkgname=brew-proxy
pkgver=a95d275e39700fce6ce88011c7df485b8586930f
pkgrel=1
pkgdesc='A more secure and multiuser-friendly way of managing linuxbrew.'
arch=('x86_64')
url=https://codeberg.org/HastD/$pkgname
license=('Apache-2.0' 'CC0-1.0' 'MIT')
makedepends=('meson' 'cargo')
source=("https://codeberg.org/HastD/$pkgname/archive/$pkgver.zip")
sha512sums=('2fd2092769a00dce846827bfe5962a4928e2fb132d628d4839a3ee27902faf3bd962ca2312613266451200f8335463c2399308adac3c3b4ee8df7b7d5b92a315')

build() {
	meson setup build -D prefix=/usr "${srcdir}/$pkgname"
	meson compile -C build
}

package() {
	DESTDIR="${pkgdir}" meson install -C build
}
